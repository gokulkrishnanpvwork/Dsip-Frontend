                                "key": "X-Admin-API-Key",
                                "value": "{{adminApiKey}}",
                                "type": "text"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/api/admin/whitelist/:email",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "whitelist",
                                ":email"
                            ],
                            "variable": [
                                {
                                    "key": "email",
                                    "value": "user@example.com",
