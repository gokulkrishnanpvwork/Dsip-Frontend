                            {
                                "key": "X-Admin-API-Key",
                                "value": "{{adminApiKey}}",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"newuser@example.com\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/admin/whitelist",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "admin",
                                "whitelist"
                            ]
                        }
                    }
                },
                {
                    "name": "Bulk Add Whitelisted Emails",
                    "request": {
                        "method": "POST",
                        "header": [
