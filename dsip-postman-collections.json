        {
            "name": "DSIP Tracker Management",
            "item": [
                {
                    "name": "Create Tracker",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"stock_symbol\": \"AAPL\",\n  \"conviction_period_years\": 5,\n  \"total_capital_planned\": 100000,\n  \"partition_days\": 30,\n  \"deployment_style\": 1,\n  \"base_conviction_score\": 75,\n  \"initial_invested_amount\": 5000,\n  \"initial_shares_held\": 25,\n  \"is_fractional_shares_allowed\": true\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/dsip-trackers",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "dsip-trackers"
                            ]
                        }
                    }
                },
                {
                    "name": "Get All Trackers (Portfolio)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/dsip-trackers",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "dsip-trackers"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Tracker Details",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/dsip-trackers/:trackerId",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "dsip-trackers",
                                ":trackerId"
                            ],
                            "variable": [
                                {
                                    "key": "trackerId",
                                    "value": "1",
                                    "description": "Tracker ID"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Update Tracker",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"deployment_style\": 2,\n  \"base_conviction_score\": 80,\n  \"status\": 1,\n  \"total_capital_planned\": 120000,\n  \"conviction_period_years\": 6,\n  \"partition_days\": 45\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/dsip-trackers/:trackerId",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "dsip-trackers",
                                ":trackerId"
                            ],
                            "variable": [
                                {
                                    "key": "trackerId",
                                    "value": "1",
                                    "description": "Tracker ID"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Execute Trade",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"lock_in_percentage\": 50,\n  \"conviction_override\": 85,\n  \"executed_amount\": 5000,\n  \"execution_price\": 176.25\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/dsip-trackers/:trackerId/execute",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "dsip-trackers",
                                ":trackerId",
                                "execute"
                            ],
                            "variable": [
                                {
                                    "key": "trackerId",
                                    "value": "1",
                                    "description": "Tracker ID"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Get Tracker Executions",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/dsip-trackers/:trackerId/executions?limit=6",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "dsip-trackers",
                                ":trackerId",
                                "executions"
                            ],
                            "query": [
                                {
                                    "key": "limit",
                                    "value": "6",
                                    "description": "Number of recent executions"
                                }
                            ],
                            "variable": [
                                {
                                    "key": "trackerId",
                                    "value": "1",
                                    "description": "Tracker ID"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Get Partition Details",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/dsip-trackers/:trackerId/partitions/:partitionIndex",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "dsip-trackers",
                                ":trackerId",
                                "partitions",
                                ":partitionIndex"
                            ],
                            "variable": [
                                {
                                    "key": "trackerId",
                                    "value": "1",
                                    "description": "Tracker ID"
                                },
                                {
                                    "key": "partitionIndex",
                                    "value": "1",
                                    "description": "Partition Index (1-based)"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Delete Tracker",
                    "request": {
                        "method": "DELETE",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/dsip-trackers/:trackerId",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "dsip-trackers",
                                ":trackerId"
                            ],
                            "variable": [
                                {
                                    "key": "trackerId",
                                    "value": "1",
                                    "description": "Tracker ID"
                                }
                            ]
                        }
                    }
                }
            ]
        },
